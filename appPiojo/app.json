{
  "expo": {
    "name": "PIOJO",
    "slug": "piojo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "piojo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chuchoivan.piojo",
      "infoPlist": {
        "NSCameraUsageDescription": "Toma fotos de las prendas para vender o donar",
        "NSPhotoLibraryUsageDescription": "Selecciona fotos de tus prendas"
      }
    },
    "android": {
      "package": "com.chuchoivan.piojo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a3f98d5-5197-4128-bdff-22d7597534db"
      }
    },
    "owner": "chuchoivan"
  }
}
